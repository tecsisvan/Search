{
  "manifest_version": 3,
  "name": "SISVAN Consulta PAI/ADRES",
  "version": "1.0.0",
  "description": "Puente entre la interfaz web SISVAN y los portales PAI / ADRES de la Secretaría Distrital de Salud.",

  "permissions": [
    "tabs",
    "scripting",
    "activeTab"
  ],

  "host_permissions": [
    "https://appb.saludcapital.gov.co/*",
    "https://*.github.io/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://appb.saludcapital.gov.co/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.github.io/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content-bridge.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_title": "SISVAN Consulta",
    "default_popup": "popup.html"
  }
}
